#!/bin/sh
cd ${0%/*} || exit 1                        # Run from this directory

echo "generateMesh"

./generateMesh

echo "END mesh generation and case preparation....."

echo "Start Running"

echo "Decompose case on 40 cores"
(cd background && decomposePar -force > log.decomposePar)
echo "RenumberMesh for parallelisation optimization"
(cd background && mpirun -hostfile hostfile -np 40 renumberMesh -parallel -overwrite > log.renumberMesh)
(echo "Run overInterDyMFoam on 40 cores :" && date)
(cd background && mpirun -hostfile hostfile -np 40 overInterDyMFoam -parallel > log.overInterDyMFoam)
(echo "End of solver calculation :" && date)

echo "END Processing"
#-------------------------------test--------------------------------------------
